# ============================================================
# OSCAR GALVAN GYM WEB — Frontend variables de entorno
# Copiá este archivo como .env y completá con tus valores.
# NUNCA subas el .env al repositorio.
#
# IMPORTANTE: Las variables VITE_ son publicas (van al bundle).
# Nunca pongas secretos aqui (JWT_SECRET, service role key, etc.)
# ============================================================

# Supabase (valores publicos, estan OK en el frontend)
# Encontras estos en: supabase.com -> tu proyecto -> Settings -> API
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key-aqui

# URL del backend Express
# Desarrollo local:
VITE_API_URL=http://localhost:3001
# En produccion (si deploys el backend):
# VITE_API_URL=https://tu-backend.railway.app
