# ============================================================
# OSCAR GALVAN GYM WEB — Backend variables de entorno
# Copiá este archivo como .env y completá con tus valores reales.
# NUNCA subas el .env al repositorio.
# ============================================================

# Supabase
# Encontrás estos datos en: supabase.com -> tu proyecto -> Settings -> API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# JWT Secret
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=genera-un-string-aleatorio-de-al-menos-64-chars

# Servidor
PORT=3001
NODE_ENV=development

# CORS: URL del frontend
FRONTEND_URL=http://localhost:5173

# Nombre del gimnasio
GYM_NOMBRE=Oscar Galvan Fuerza y Musculacion

# Email / SMTP (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password
