# Supabase — encontrás estos datos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# JWT — generá un string aleatorio largo y secreto
JWT_SECRET=un-string-largo-y-secreto-aqui

# Servidor
PORT=3001
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173
